{
  "name": "envelope",
  "private": true,
  "version": "0.0.1",
  "description": "Private programmable treasury & payroll OS for crypto-native global businesses",
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint",
    "typecheck": "pnpm -r typecheck",
    "cloak:spike": "tsx scripts/cloak-spike.ts",
    "seed:comp": "tsx scripts/seed-comp-csv.ts",
    "sns:bootstrap": "tsx scripts/sns-bootstrap.ts"
  },
  "devDependencies": {
    "@bonfida/spl-name-service": "3.0.21",
    "@solana/web3.js": "^1.98.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  }
}
