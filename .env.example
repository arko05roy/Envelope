# ===== Solana =====
NEXT_PUBLIC_SOLANA_NETWORK=devnet                     # devnet | mainnet-beta
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_KEYPAIR_PATH=/Users/you/.config/solana/id.json # for server-side scripts only
NEXT_PUBLIC_TREASURY_PUBKEY=                          # dWallet's Solana pubkey (Ika)

# ===== Privy (wallet auth) =====
NEXT_PUBLIC_PRIVY_APP_ID=

# ===== Cloak =====
# program id is fixed: zh1eLd6rSphLejbFfJEneUwzHRfMKxgzrgkfwA6qRkW
NEXT_PUBLIC_CLOAK_RELAY_URL=https://api.cloak.ag

# ===== KIRAPAY =====
# Get x-api-key from https://dashboard.kira-pay.com (Verify → onboard → copy key)
# Auth header: x-api-key: $KIRAPAY_API_KEY
KIRAPAY_API_KEY=
KIRAPAY_BASE_URL=https://api.kira-pay.com/api
# Whatever secret you pass when registering the webhook (POST /api/webhooks).
# We HMAC-SHA256 the raw body with this and compare to x-kirapay-signature.
KIRAPAY_WEBHOOK_SECRET=whsec_change_me

# ===== Dodo Payments (Standard Webhooks spec — Svix compat) =====
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode                   # test_mode | live_mode
DODO_PAYMENTS_RETURN_URL=http://localhost:3000/checkout/success
DODO_PAYMENTS_WEBHOOK_KEY=                            # whsec_… from dashboard webhook detail page
DODO_PRODUCT_ID_SUBSCRIPTION=

# ===== Ika =====
NEXT_PUBLIC_IKA_NETWORK=solana-devnet
IKA_NETWORK_RPC=                                       # provided by Ika

# ===== Encrypt =====
ENCRYPT_PROGRAM_ID=                                    # set after deploy
ENCRYPT_DECRYPTOR_URL=                                 # pre-alpha decryptor service

# ===== SNS (Solana Name Service identity track) =====
# Mainnet RPC for resolving public .sol handles. Defaults to public RPC if unset.
HELIUS_MAINNET_RPC_URL=
# Optional explicit devnet override. Falls back to NEXT_PUBLIC_HELIUS_RPC_URL.
HELIUS_DEVNET_RPC_URL=
# Org's parent .sol domain (without .sol). Empty = SNS features disabled.
NEXT_PUBLIC_SNS_PARENT_DOMAIN=
# Subdomain that signs payroll batches. Combined as <agent>.<parent>.sol.
NEXT_PUBLIC_SNS_AGENT_SUBDOMAIN=payroll-agent
# Cluster the parent domain is registered on.
NEXT_PUBLIC_SNS_PARENT_CLUSTER=devnet                  # devnet | mainnet
# Used by `pnpm sns:bootstrap` only (not loaded by Next.js).
SNS_PARENT_DOMAIN=
SNS_SUBDOMAINS=                                        # comma-separated, e.g. alice,bob,payroll-agent
