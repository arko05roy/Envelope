# ===== Solana =====
NEXT_PUBLIC_SOLANA_NETWORK=devnet                     # devnet | mainnet-beta
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_KEYPAIR_PATH=/Users/you/.config/solana/id.json # for server-side scripts only
NEXT_PUBLIC_TREASURY_PUBKEY=                          # dWallet's Solana pubkey (Ika)

# ===== Privy (wallet auth) =====
NEXT_PUBLIC_PRIVY_APP_ID=

# ===== Cloak =====
# program id is fixed: zh1eLd6rSphLejbFfJEneUwzHRfMKxgzrgkfwA6qRkW
NEXT_PUBLIC_CLOAK_RELAY_URL=https://api.cloak.ag

# ===== KIRAPAY =====
# Get x-api-key from https://dashboard.kira-pay.com (Verify → onboard → copy key)
# Auth header: x-api-key: $KIRAPAY_API_KEY
KIRAPAY_API_KEY=
KIRAPAY_BASE_URL=https://api.kira-pay.com/api
# Whatever secret you pass when registering the webhook (POST /api/webhooks).
# We HMAC-SHA256 the raw body with this and compare to x-kirapay-signature.
KIRAPAY_WEBHOOK_SECRET=whsec_change_me

# ===== Dodo Payments =====
DODO_API_KEY=
DODO_WEBHOOK_SIGNING_KEY=
DODO_PRODUCT_ID_SUBSCRIPTION=

# ===== Ika =====
NEXT_PUBLIC_IKA_NETWORK=solana-devnet
IKA_NETWORK_RPC=                                       # provided by Ika

# ===== Encrypt =====
ENCRYPT_PROGRAM_ID=                                    # set after deploy
ENCRYPT_DECRYPTOR_URL=                                 # pre-alpha decryptor service
